# G0 spike configuration — copy to .env.spike and fill in.
#
#   cp .env.spike.example .env.spike
#   chmod 600 .env.spike
#
# .env.spike is gitignored. Nothing in this repo prints its contents, and the
# spike script redacts every value it loads. Do not paste the private key into
# a chat, a terminal you are screen-sharing, or a prompt.
#
# ---------------------------------------------------------------------------
# RULES FOR THIS KEY — it is a throwaway, not a wallet you care about
# ---------------------------------------------------------------------------
#   * Generate a BRAND NEW wallet for this spike. Never reuse the x402 payment
#     wallet, the Agent #5560 identity wallet, or anything holding real balance.
#   * Fund it with the minimum that lets one order rest — a couple of dollars.
#   * Run this on your laptop or a scratch box. NOT on the production VPS.
#   * When G0 is signed off, drain it and discard the key.
#
# To generate one locally (never prints to a shared terminal):
#   python -c "from eth_account import Account; a=Account.create(); \
#     print(a.key.hex()); print(a.address)"

# The throwaway EOA private key (0x-prefixed hex). REQUIRED.
SPIKE_PRIVATE_KEY=

# The address that holds the funds. For an EOA setup this equals the address
# derived from SPIKE_PRIVATE_KEY. For a POLY_1271 deposit wallet it is the
# deposit wallet address and the key above is the authorized signer.
SPIKE_FUNDER_ADDRESS=

# Polymarket signature type: 0 = EOA, 1 = POLY_PROXY, 2 = GNOSIS_SAFE,
# 3 = POLY_1271. Start at 0 for the simplest possible proof.
SPIKE_SIGNATURE_TYPE=0

# The market to rest an order in. Use a liquid market and a price far from the
# touch so the order rests instead of filling. Fill both from
# scripts/g0_spike.py --pick-market.
SPIKE_TOKEN_ID=
SPIKE_CONDITION_ID=

# Order parameters. Keep tiny. Price must be on-tick; size at or above the
# venue minimum (currently 5).
SPIKE_SIDE=BUY
SPIKE_PRICE=0.02
SPIKE_SIZE=5

# Chain / host. Polygon mainnet is 137.
SPIKE_CHAIN_ID=137
SPIKE_CLOB_HOST=https://clob.polymarket.com
